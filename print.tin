;;;;                                                                      ;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defnet print-buffers-content-cb (self)
        (print-clear)
        (opt (print-buffers-content-low 1))
        (opt (print-buffers-content-low 2)) )

(defnet print-buffers-content-low (which)
        (deflocal av i fmin fmax ts skip dupl)

        (set av <_kv (+ "av" which)>)
        (<> av undef)
        (print-append (+ "Buffer content - movie " which " (size=" (av-get-buf-size av) "): " nl nl))
        (for i in (av-get-buf-content av) do
                (print-append (+ "[" (int->str (+ (for-pos) 1) 4 '0') "] "))
                (if (= i undef)
                then    (print-append-nl "~~~ break ~~~")
                else    (set fmin <i 0>)
                        (set fmax <i 1>)
                        (set ts <i 2>)
                        (set skip <i 3>)
                        (set dupl (- fmax fmin))
                        (print-append (+
                                (int->str fmin 6 '0') "-" (int->str fmax 6 '0') " ts=" (approx4 ts)
                                (if (> dupl 0) (+ " ← " dupl " " (if (= dupl 1) $"duplicate" $"duplicates")) "")
                                (if (> skip 0) (+ " ← " skip " " "skipped") "")
                                nl ))))
        (print-append nl) )

