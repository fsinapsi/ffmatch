;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defnet print-clear ()
        (setup-text-reset 2)
        (iup-post-call (netptr print-clear-post)) )

(defnet print-clear-post ()
        (deflocal text2)

        (set text2 <_kv "text2">)
        (iup-set-int text2 "CARETPOS" (iup-get-int text2 "COUNT")) )

(defnet print-append (msg)
        (iup-text-append-and-go-end <_kv "text2"> msg) )

(defnet print-append-color (color msg)
        (iup-text-append-and-go-end-color <_kv "text2"> color msg) )

(defnet print-append-nl (msg)
        (print-append msg)
        (print-append nl) )

(defnet print-append-color-nl (color msg)
        (print-append-color color msg)
        (print-append nl) )

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;                                                                      ;;;;
;;;;                                                                      ;;;;
;;;;                                                                      ;;;;
;;;;                                                                      ;;;;
;;;;                                                                      ;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;

(defnet print-info-on-selected-file (which)
        (opt (print-info-on-selected-file-low which)) )

(defnet print-info-on-selected-file-low (which)
        (deflocal av vidx s t)

        (set av <_kv (+ "av" which)>)
        (<> av undef)
        (set vidx (av-video-stream-idx av))
        (print-append (+ $"movie" " " which ": "))
        (print-append-color-nl (blue) (fullpath->name (av-path av)))
        (set s (av-get-accel av))
        (if (> s 0)
        then    (print-append "hw accel: ")
                (print-append-color-nl (blue) <(hwaccels) s>) )
        (set s (av-last-error av))
        (if (<> s [ "" . "no error" ])
        then    (print-append "last error: ")
                (print-append-color (blue) (cdr s))
                (print-append " [")
                (print-append-color (blue) (car s))
                (print-append-nl "]") )
        (print-append
                (+ $"resolution" ": ") )
        (print-append-color-nl (blue)
                (sprint (width av) " x " (height av)) )
        (set s (av-par av))
        (if (<> s 1)
        then    (print-append
                        (+ $"display resolution" ": ") )
                (print-append-color-nl (blue)
                        (if (< s 1)
                        (sprint (width av) " x " (rint (/ (height av) s)))
                        (sprint (rint (* (width av) s)) " x " (height av)) )))
        (set s (av-dar av))
        (set t (av-original-dar av))
        (print-append "aspect ratio: ")
        (print-append-color-nl (blue) (+
                (if (and (< (num s) 1000) (< (den s) 1000))
                        (sprint (num s) ":" (den s) " = ")
                        "" )
                (approx3 s)
                (dump-ar-circa s (/ 4 3) "4:3")
                (dump-ar-circa s (/ 16 9) "16:9")
                (dump-ar-circa s 1.85 "1.85:1")
                (dump-ar-circa s 2.35 "2.35:1") ))
        (if (<> s t)
        then    (print-append (+ $"original aspect ratio" ": "))
                (print-append-color-nl (blue) (+
                        (if (and (< (num t) 1000) (< (den t) 1000))
                                (sprint (num t) ":" (den t) " = ")
                                "" )
                        (approx3 t)
                        (dump-ar-circa t (/ 4 3) "4:3")
                        (dump-ar-circa t (/ 16 9) "16:9")
                        (dump-ar-circa t 1.85 "1.85:1")
                        (dump-ar-circa t 2.35 "2.35:1") )))
        (set s (av-video-frame-rate av))
        (set t (av-original-video-frame-rate av))
        (print-append "framerate: ")
        (print-append-color (blue) (approx6 s))
        (print-append-nl " fps")
        (if (<> s t)
        then    (print-append (+ $"original framerate" ": "))
                (print-append-color (blue) (approx6 t))
                (print-append-nl " fps") )
        (set s (av-duration av))
        (set t (av-video-duration av))
        (print-append (+ $"duration" ": "))
        (print-append-color (blue) (date-s2hhmmss s))
        (print-append " (")
        (print-append-color (blue) (approx3 s))
        (print-append-nl " s)")
        (if (and (rationalp t) (<> s t))
        then    (print-append (+ $"video stream duration" ": "))
                (print-append-color (blue) (date-s2hhmmss t))
                (print-append " (")
                (print-append-color (blue) (approx3 t))
                (print-append-nl " s)") )
        (print-append (+ $"approximate number of frames" ": "))
        (print-append-color-nl (blue) (av-approximated-number-of-frames av))
        (print-append "pixel format: ")
        (print-append-color-nl (blue) (av-get-pix-fmt av))
        (set s (av-get-hw-pix-fmt av))
        (if (stringp s)
        then    (print-append "accel pixel format: ")
                (print-append-color-nl (blue) s) )
        (print-append "codec: ")
        (print-append-color (blue) (av-codec-id av vidx))
        (print-append " (decoder: ")
        (print-append-color (blue) (av-codec-name av vidx))
        (print-append-nl ")")
        (set s (av-get-filter-rows av))
        (if (> s 0)
        then    (print-append (+ $"deinterlacing" ": "))
                (print-append-color-nl (blue) <(deinterlacing) s>) )
        (set s (av-get-filter av))
        (if (stringp s)
        then    (print-append "avfilter chain: ")
                (print-append-color-nl (blue) s) )
        (set s (av-get-gamma av))
        (if (<> s 1)
        then    (print-append (+ $"gamma correction" ": "))
                (print-append-color-nl (blue) (approx3 s)) )
        (set s (av-get-contrast av))
        (if (<> s 1)
        then    (print-append (+ $"contrast" ": "))
                (print-append-color-nl (blue) (approx3 s)) )
        (set s (av-get-hue av))
        (if (<> s [ 0 . 0 ])
        then    (print-append (+ $"hue" ": "))
                (print-append-color (blue) (approx3 (car s)))
                (print-append (+ " " $"saturation" ": "))
                (print-append-color-nl (blue) (approx3 (cdr s))) )
        (set s (av-get-temperature av))
        (if (<> s [ 0 . 0 ])
        then    (print-append (+ $"temperature" ": "))
                (print-append-color (blue) (approx3 (car s)))
                (print-append (+ " " $"angle" ": "))
                (print-append-color-nl (blue) (approx3 (cdr s))) )
        (if (av-get-hflip av)
        then    (print-append "mirror: ")
                (print-append-color-nl (blue) $"enabled") )
        (if (av-get-vflip av)
        then    (print-append "flip: ")
                (print-append-color-nl (blue) $"enabled") )
        (print-append nl) )

;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;;;;                                                                      ;;;;
;;;;                                                                      ;;;;
;;;;                                                                      ;;;;
